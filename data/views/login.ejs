<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Finanças da Igreja</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #eff6ff, #f8fafc);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .login-box {
      width: 100%;
      max-width: 420px;
      background: #ffffff;
      border-radius: 18px;
      padding: 30px;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.12);
      border-top: 6px solid #1d4ed8;
      text-align: center;
    }

    .login-box img {
      width: 110px;
      height: 110px;
      object-fit: contain;
      margin-bottom: 10px;
    }

    .login-box h1 {
      margin: 0;
      color: #1e3a8a;
      font-size: 22px;
    }

    .login-box p {
      color: #6b7280;
      margin: 8px 0 20px;
    }

    .flash {
      margin-bottom: 14px;
      padding: 10px;
      border-radius: 8px;
      font-size: 14px;
    }

    .erro {
      background: #fee2e2;
      color: #991b1b;
    }

    .sucesso {
      background: #dcfce7;
      color: #166534;
    }

    label {
      display: block;
      text-align: left;
      margin-bottom: 6px;
      font-weight: bold;
      color: #374151;
    }

    input {
      width: 100%;
      padding: 12px;
      margin-bottom: 16px;
      border-radius: 8px;
      border: 1px solid #cbd5e1;
      font-size: 15px;
    }

    button {
      width: 100%;
      padding: 12px;
      background: #1d4ed8;
      color: white;
      border: none;
      border-radius: 8px;
      font-weight: bold;
      cursor: pointer;
      font-size: 15px;
    }

    button:hover {
      background: #f97316;
    }

    .help {
      margin-top: 14px;
      font-size: 13px;
      color: #6b7280;
    }
  </style>
</head>
<body>
  <div class="login-box">
    <img src="/images/logo.jpg" alt="Logo Igreja">

    <h1>Assembleia de Deus</h1>
    <p>Finanças da Igreja</p>

    <% if (flash) { %>
      <div class="flash <%= flash.tipo %>"><%= flash.texto %></div>
    <% } %>

    <form method="POST" action="/login">
      <label for="username">Usuário</label>
      <input id="username" type="text" name="username" required>

      <label for="senha">Senha</label>
      <input id="senha" type="password" name="senha" required>

      <button type="submit">Entrar</button>
    </form>

    <div class="help">Igreja de Deus: <strong>Transparência</strong> / <strong>Financeira</strong></div>
  </div>
</body>
</html>