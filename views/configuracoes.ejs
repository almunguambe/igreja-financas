<%- include('_layout_start', { title: 'Configurações', user, flash }) %>
<div class="card">
  <h2>Transportes por Ano</h2>
  <form method="post" action="/configuracoes">
    <div class="row">
      <div><label>Ano</label><input type="number" name="ano" value="2026" required></div>
      <div><label>Transporte Banco</label><input type="number" step="0.01" name="transporte_banco" required></div>
      <div><label>Transporte Caixa</label><input type="number" step="0.01" name="transporte_caixa" required></div>
    </div>
    <button type="submit">Guardar Configuração</button>
  </form>
</div>
<div class="card">
  <table>
    <thead><tr><th>Ano</th><th>Transporte Banco</th><th>Transporte Caixa</th></tr></thead>
    <tbody>
      <% configs.forEach(item => { %>
      <tr><td><%= item.ano %></td><td><%= Number(item.transporte_banco).toLocaleString('pt-MZ') %></td><td><%= Number(item.transporte_caixa).toLocaleString('pt-MZ') %></td></tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('_layout_end') %>
