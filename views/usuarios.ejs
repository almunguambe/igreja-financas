<%- include('_layout_start', { title: 'Usuários', user, flash }) %>
<div class="card">
  <h2>Novo Usuário</h2>
  <form method="post" action="/usuarios">
    <div class="row">
      <div><label>Nome</label><input name="nome" required></div>
      <div><label>Usuário</label><input name="username" required></div>
      <div><label>Senha</label><input type="password" name="senha" required></div>
      <div><label>Perfil</label><select name="perfil"><option>admin</option><option>tesoureiro</option><option>visualizador</option></select></div>
    </div>
    <button type="submit">Criar Usuário</button>
  </form>
</div>
<div class="card">
  <table>
    <thead><tr><th>Nome</th><th>Usuário</th><th>Perfil</th><th>Ativo</th></tr></thead>
    <tbody>
      <% users.forEach(item => { %>
      <tr><td><%= item.nome %></td><td><%= item.username %></td><td><%= item.perfil %></td><td><%= item.ativo ? 'Sim' : 'Não' %></td></tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('_layout_end') %>
